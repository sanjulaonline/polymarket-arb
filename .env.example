# ── Polymarket ────────────────────────────────────────────────────────────────
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_passphrase
POLYMARKET_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY
# Wallet queried via ERC20 balanceOf for paper bankroll bootstrap
PROXY_WALLET=0xYOUR_PROXY_WALLET_ADDRESS
# Polygon RPC for on-chain balanceOf calls
POLYGON_RPC_URL=https://polygon.publicnode.com
# Comma-separated fallbacks used if POLYGON_RPC_URL fails (401/403/rate-limit/etc.)
POLYGON_RPC_FALLBACK_URLS=https://polygon.drpc.org,https://polygon-bor-rpc.publicnode.com,https://rpc.ankr.com/polygon

# ── CryptoQuant (optional — Binance WS is primary) ────────────────────────────
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key

# ── TradingView (no key needed — uses public feed) ────────────────────────────
TV_SYMBOL_BTC=BINANCE:BTCUSDT
TV_SYMBOL_ETH=BINANCE:ETHUSDT
# Enabled BTC Polymarket contract windows: 5m, 15m, or both comma-separated
MARKET_TIMEFRAMES=5m,15m

# ── Strategy ──────────────────────────────────────────────────────────────────
# Min lag in percentage points to scan (3pp = "3 percentage points")
LAG_THRESHOLD_PP=3.0
# Min edge % to place a trade (5% = image spec)
MIN_EDGE_PCT=5.0
# Max position as % of portfolio (8% = image spec)
MAX_POSITION_PCT=8.0
# Max total open exposure across all active positions (% of portfolio)
# Example: 16 means two 8%-sized positions can be open simultaneously
MAX_TOTAL_EXPOSURE_PCT=16.0
# Min confidence score 0–1 (0.85 = image spec)
MIN_CONFIDENCE=0.85
# Kelly multiplier — 0.5 = half-Kelly (image spec)
KELLY_FRACTION=0.5
# Kill-switch: halt all trading if daily drawdown exceeds this % (20% = image spec)
DAILY_DRAWDOWN_KILL_PCT=20.0
# Risk per trade as % of portfolio
RISK_PCT_PER_TRADE=0.5
# Hard max order size in USDC
MAX_ORDER_SIZE_USDC=800
# Portfolio size in USDC (for risk math)
# In paper mode, bankroll source priority is:
# 1) Polygon USDC.e balanceOf(PROXY_WALLET)
# 2) CLOB collateral balance
# 3) PORTFOLIO_SIZE_USDC fallback
PORTFOLIO_SIZE_USDC=10000
# Polymarket poll interval in ms
POLY_POLL_MS=200
# HTTP execution timeout in ms (Polymarket requests)
EXEC_TIMEOUT_MS=5000

# ── Trading Mode ──────────────────────────────────────────────────────────────
# Paper trading by default — safe
PAPER_TRADING=true

# To go LIVE, ALL THREE must be set to "true" AND PAPER_TRADING=false
# This triple-flag requirement prevents accidental live trading
LIVE_FLAG_1=false
LIVE_FLAG_2=false
LIVE_FLAG_3=false

# ── Log Level ─────────────────────────────────────────────────────────────────
RUST_LOG=info
# Set true to enable ratatui dashboard. Default false = console logs only.
ENABLE_TUI=false

# ── Bayesian Model ────────────────────────────────────────────────────────────
# Prior strength: how many pseudo-observations to give the market's initial odds
# Higher = slower to update (trust market more). Lower = faster (trust our data)
# Typical: 5 (aggressive) – 20 (conservative)
BAYES_PRIOR_STRENGTH=10.0
# Evidence decay half-life in seconds — older ticks count exponentially less
# 30s = recent ticks dominate. 120s = slower, smoother posterior
BAYES_HALF_LIFE_SECS=30.0

# ── Stoikov Model ─────────────────────────────────────────────────────────────
# Risk-aversion γ: higher = wider spread, more inventory penalty
# 0.1 = aggressive market maker, 0.5 = moderate, 1.0 = conservative
STOIKOV_GAMMA=0.3
# Order arrival intensity κ: higher = tighter spread (more liquid markets)
STOIKOV_KAPPA=1.5
# Rolling volatility window (number of price ticks to keep)
STOIKOV_VOL_WINDOW=60
